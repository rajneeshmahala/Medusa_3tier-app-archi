NODE_ENV=production
PORT={{ medusa_port }}

# Database
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@{{ db_host }}:{{ db_port }}/{{ db_name }}

# Secrets
JWT_SECRET={{ jwt_secret }}
COOKIE_SECRET={{ cookie_secret }}

# CORS — allow VM1 (storefront + admin)
STORE_CORS=http://{{ hostvars[groups['web'][0]]['ansible_host'] }},http://{{ hostvars[groups['web'][0]]['ansible_host'] }}:8000
ADMIN_CORS=http://{{ hostvars[groups['web'][0]]['ansible_host'] }},http://{{ hostvars[groups['web'][0]]['ansible_host'] }}:7001
AUTH_CORS=http://{{ hostvars[groups['web'][0]]['ansible_host'] }},http://{{ hostvars[groups['web'][0]]['ansible_host'] }}:8000,http://{{ hostvars[groups['web'][0]]['ansible_host'] }}:7001

# File storage
UPLOAD_DIR=/opt/medusa-backend/uploads
